<!DOCTYPE html>
<html lang="zh-Hant">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>旅結 Pro | 修正版</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <style>
        :root { --navy: #0369a1; }
        body { font-family: 'Noto Sans TC', sans-serif; background: #f8fafc; }
        .tab-active { color: var(--navy); border-bottom: 3px solid var(--navy); font-weight: bold; }
        .action-btn:active { transform: scale(0.95); }
    </style>
</head>
<body class="min-h-screen pb-10">

    <div id="view-home" class="max-w-md mx-auto px-6 pt-10">
        <header class="mb-10 text-center">
            <h1 class="text-3xl font-bold text-sky-900 tracking-tighter">旅結 <span class="text-amber-500 italic">Tabi Pro</span></h1>
            <p class="text-gray-400 text-[10px] mt-1 uppercase tracking-widest">Journey Manager</p>
        </header>

        <div class="bg-white p-6 rounded-[2rem] shadow-xl mb-8 border border-sky-50">
            <h3 class="text-sm font-bold text-gray-700 mb-4">建立新旅程</h3>
            <input type="text" id="newTripInput" placeholder="例如：2026 北海道之行" class="w-full bg-gray-50 px-5 py-4 rounded-2xl focus:outline-none mb-3 border-none">
            <button onclick="h_createTrip()" class="w-full bg-sky-900 text-white py-4 rounded-2xl font-bold shadow-lg action-btn">開始新旅程</button>
        </div>

        <h3 class="text-[10px] font-bold text-gray-400 mb-4 uppercase tracking-widest">我的旅程清單</h3>
        <div id="h_tripList" class="space-y-4"></div>
    </div>

    <div id="view-detail" class="hidden max-w-md mx-auto px-6 pt-6">
        <div class="flex items-center justify-between mb-4">
            <button onclick="h_goHome()" class="text-sky-800 text-sm flex items-center gap-1 font-medium">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg> 返回
            </button>
            <h2 id="d_tripTitle" class="text-lg font-bold text-sky-900 truncate max-w-[150px]"></h2>
            <button onclick="h_copyMsg()" class="text-emerald-600 text-xs font-bold bg-emerald-50 px-3 py-1 rounded-full action-btn">分享結算</button>
        </div>

        <div class="bg-white rounded-[2rem] p-6 shadow-xl mb-6 border border-sky-50">
            <div class="h-40 w-full mb-4"><canvas id="d_chart"></canvas></div>
            <div class="text-center">
                <p class="text-[10px] text-gray-400 uppercase tracking-widest">目前總支出</p>
                <h3 id="d_totalAmt" class="text-3xl font-bold text-sky-900">$ 0.00</h3>
            </div>
        </div>

        <div class="flex mb-6 border-b border-gray-100 text-sm overflow-x-auto">
            <button onclick="h_switchTab('add')" id="tab-add" class="flex-1 py-3 tab-active">記帳</button>
            <button onclick="h_switchTab('list')" id="tab-list" class="flex-1 py-3 text-gray-400">紀錄</button>
            <button onclick="h_switchTab('settle')" id="tab-settle" class="flex-1 py-3 text-gray-400">結算</button>
            <button onclick="h_switchTab('mem')" id="tab-mem" class="flex-1 py-3 text-gray-400">成員</button>
        </div>

        <div id="p-add" class="space-y-4">
            <div class="flex gap-2">
                <select id="i_cat" class="bg-white px-3 py-4 rounded-2xl shadow-sm text-sm border-none ring-1 ring-gray-100">
                    <option value="食">🍴 食</option><option value="住">🏨 住</option><option value="行">🚗 行</option><option value="玩">🎟️ 玩</option><option value="購">🛍️ 購</option>
                </select>
                <input type="text" id="i_name" placeholder="項目名稱" class="flex-1 bg-white px-5 py-4 rounded-2xl shadow-sm border-none ring-1 ring-gray-100">
            </div>
            <input type="number" id="i_amt" placeholder="金額 (HKD)" class="w-full bg-white px-5 py-4 rounded-2xl shadow-sm border-none ring-1 ring-gray-100">
            <div class="bg-white p-5 rounded-3xl shadow-sm ring-1 ring-gray-50 space-y-4">
                <div class="flex justify-between items-center text-sm"><span class="font-bold text-gray-500">誰付的？</span><select id="i_payer" class="bg-sky-50 px-3 py-2 rounded-xl text-sky-900 font-bold border-none"></select></div>
                <hr class="border-gray-50">
                <p class="text-[10px] font-bold text-gray-400 uppercase">為誰代付？</p>
                <div id="i_splitList" class="grid grid-cols-2 gap-3"></div>
            </div>
            <button onclick="h_saveExpense()" class="w-full bg-sky-900 text-white py-5 rounded-3xl font-bold shadow-lg action-btn">記入帳目</button>
        </div>

        <div id="p-list" class="hidden space-y-3">
            <button onclick="h_clearAll()" class="w-full py-2 text-[10px] text-red-400 border border-red-100 rounded-xl mb-2">清空所有紀錄</button>
            <div id="d_expList" class="space-y-3"></div>
        </div>
        <div id="p-settle" class="hidden space-y-3"><div id="d_settleList" class="bg-white rounded-3xl p-6 space-y-4 text-sm"></div></div>
        <div id="p-mem" class="hidden space-y-4">
            <div class="bg-white p-6 rounded-3xl shadow-sm">
                <p class="text-sm font-bold mb-4">新增旅伴</p>
                <div class="flex gap-2 mb-4"><input type="text" id="i_newMem" placeholder="名字" class="flex-1 bg-gray-50 px-4 py-2 rounded-xl text-sm border-none"><button onclick="h_addMember()" class="bg-sky-800 text-white px-4 py-2 rounded-xl text-sm">加入</button></div>
                <div id="d_memList" class="flex flex-wrap gap-2"></div>
            </div>
        </div>
    </div>

    <script>
        let allTrips = JSON.parse(localStorage.getItem('tabi_v4_data')) || [];
        let activeIdx = -1;
        let myChart = null;

        function h_saveData() {
            localStorage.setItem('tabi_v4_data', JSON.stringify(allTrips));
            h_renderTripList();
            if(activeIdx !== -1) h_refreshDetail();
        }

        function h_createTrip() {
            const name = document.getElementById('newTripInput').value.trim();
            if(!name) return;
            const newTrip = { name, members: ["我"], expenses: [] };
            allTrips.push(newTrip);
            h_saveData();
            document.getElementById('newTripInput').value = '';
            // 關鍵修正：建立後立刻進入該旅程
            h_openTrip(allTrips.length - 1);
        }

        function h_openTrip(idx) {
            activeIdx = idx;
            document.getElementById('view-home').classList.add('hidden');
            document.getElementById('view-detail').classList.remove('hidden');
            h_refreshDetail();
            h_switchTab('add');
        }

        function h_goHome() {
            activeIdx = -1;
            document.getElementById('view-home').classList.remove('hidden');
            document.getElementById('view-detail').classList.add('hidden');
            h_renderTripList();
        }

        function h_renderTripList() {
            const container = document.getElementById('h_tripList');
            container.innerHTML = allTrips.length ? allTrips.map((t, i) => `
                <div onclick="h_openTrip(${i})" class="bg-white p-5 rounded-[2rem] shadow-sm flex justify-between items-center cursor-pointer border border-sky-50">
                    <div><h4 class="font-bold text-sky-900">${t.name}</h4><p class="text-[10px] text-gray-400">${t.members.length} 位成員 · ${t.expenses.length} 筆開支</p></div>
                    <button onclick="h_deleteTrip(${i}, event)" class="text-gray-300 hover:text-red-400 text-xs">刪除</button>
                </div>
            `).join('') : '<p class="text-center text-gray-400 py-10 text-xs">輸入旅程名字開始記帳！</p>';
        }

        function h_refreshDetail() {
            const trip = allTrips[activeIdx];
            if(!trip) return;
            document.getElementById('d_tripTitle').innerText = trip.name;
            const total = trip.expenses.reduce((s, e) => s + e.amt, 0);
            document.getElementById('d_totalAmt').innerText = `$ ${total.toFixed(2)}`;
            document.getElementById('i_payer').innerHTML = trip.members.map(m => `<option value="${m}">${m}</option>`).join('');
            document.getElementById('i_splitList').innerHTML = trip.members.map(m => `
                <label class="flex items-center gap-2 p-3 bg-gray-50 rounded-2xl text-[10px] font-bold cursor-pointer">
                    <input type="checkbox" value="${m}" checked class="w-4 h-4 accent-sky-800"> ${m}
                </label>
            `).join('');
            document.getElementById('d_memList').innerHTML = trip.members.map(m => `<span class="bg-sky-50 text-sky-800 px-3 py-1 rounded-full text-xs font-bold">${m}</span>`).join('');
            document.getElementById('d_expList').innerHTML = trip.expenses.map((e, idx) => `
                <div class="bg-white p-4 rounded-2xl shadow-sm flex justify-between items-center">
                    <div><p class="text-xs font-bold text-sky-900">${e.cat} | ${e.name}</p><p class="text-[9px] text-gray-400">由 ${e.payer} 代付</p></div>
                    <div class="flex items-center gap-3"><span class="font-bold text-sm">$${e.amt}</span><button onclick="h_deleteExp(${idx})" class="text-red-200">×</button></div>
                </div>
            `).reverse().join('');
            h_updateChart();
        }

        function h_saveExpense() {
            const name = document.getElementById('i_name').value || "未命名項目";
            const amt = parseFloat(document.getElementById('i_amt').value);
            const cat = document.getElementById('i_cat').value;
            const payer = document.getElementById('i_payer').value;
            const split = Array.from(document.querySelectorAll('#i_splitList input:checked')).map(c => c.value);
            if(!amt || !split.length) return alert("請填寫金額與分擔者");
            allTrips[activeIdx].expenses.push({ name, amt, cat, payer, split });
            document.getElementById('i_name').value = '';
            document.getElementById('i_amt').value = '';
            h_saveData();
            alert("已記錄！");
        }

        function h_deleteExp(idx) {
            allTrips[activeIdx].expenses.splice(allTrips[activeIdx].expenses.length - 1 - idx, 1);
            h_saveData();
        }

        function h_deleteTrip(idx, e) {
            e.stopPropagation();
            if(confirm("刪除旅程？")) { allTrips.splice(idx, 1); h_saveData(); }
        }

        function h_clearAll() {
            if(confirm("清空帳目？")) { allTrips[activeIdx].expenses = []; h_saveData(); }
        }

        function h_addMember() {
            const n = document.getElementById('i_newMem').value.trim();
            if(n && !allTrips[activeIdx].members.includes(n)) {
                allTrips[activeIdx].members.push(n);
                document.getElementById('i_newMem').value = '';
                h_saveData();
            }
        }

        function h_switchTab(tab) {
            ['add', 'list', 'settle', 'mem'].forEach(t => {
                document.getElementById(`p-${t}`).classList.add('hidden');
                document.getElementById(`tab-${t}`).classList.remove('tab-active');
                document.getElementById(`tab-${t}`).classList.add('text-gray-400');
            });
            document.getElementById(`p-${tab}`).classList.remove('hidden');
            document.getElementById(`tab-${tab}`).classList.add('tab-active');
            document.getElementById(`tab-${tab}`).classList.remove('text-gray-400');
            if(tab === 'settle') h_runSettle();
        }

        function h_runSettle() {
            const trip = allTrips[activeIdx];
            let bal = {}; trip.members.forEach(m => bal[m] = 0);
            trip.expenses.forEach(e => {
                const s = e.amt / e.split.length;
                bal[e.payer] += e.amt; e.split.forEach(p => { if(bal.hasOwnProperty(p)) bal[p] -= s; });
            });
            const res = document.getElementById('d_settleList');
            res.innerHTML = '<p class="text-[10px] font-bold text-gray-400 text-center uppercase mb-2">建議清數方案</p>';
            let g = [], r = [];
            for(let p in bal) { if(bal[p] < -0.1) g.push({n:p, a:Math.abs(bal[p])}); else if(bal[p] > 0.1) r.push({n:p, a:bal[p]}); }
            if(!g.length) res.innerHTML += '<p class="text-center py-4 text-gray-300">帳目已平整</p>';
            g.forEach(gv => { r.forEach(rv => { if(gv.a > 0 && rv.a > 0) { let v = Math.min(gv.a, rv.a);
                res.innerHTML += `<div class="flex justify-between p-4 bg-sky-50 rounded-2xl"><span><b>${gv.n}</b> ➔ <b>${rv.n}</b></span><b>$${v.toFixed(2)}</b></div>`;
                gv.a -= v; rv.a -= v;
            }})});
        }

        function h_copyMsg() {
            const trip = allTrips[activeIdx];
            let msg = `🏮 ${trip.name} 結算清單\n------------------\n`;
            let bal = {}; trip.members.forEach(m => bal[m] = 0);
            trip.expenses.forEach(e => {
                const s = e.amt / e.split.length;
                bal[e.payer] += e.amt; e.split.forEach(p => { if(bal.hasOwnProperty(p)) bal[p] -= s; });
            });
            let g = [], r = [];
            for(let p in bal) { if(bal[p] < -0.1) g.push({n:p, a:Math.abs(bal[p])}); else if(bal[p] > 0.1) r.push({n:p, a:bal[p]}); }
            g.forEach(gv => { r.forEach(rv => { if(gv.a > 0 && rv.a > 0) { let v = Math.min(gv.a, rv.a); msg += `👉 ${gv.n} ➔ ${rv.n} : $${v.toFixed(2)}\n`; gv.a -= v; rv.a -= v; }})});
            navigator.clipboard.writeText(msg).then(() => alert("已複製結算訊息！"));
        }

        function h_updateChart() {
            const trip = allTrips[activeIdx];
            const cats = { '食': 0, '住': 0, '行': 0, '玩': 0, '購': 0 };
            trip.expenses.forEach(e => cats[e.cat] += e.amt);
            const ctx = document.getElementById('d_chart').getContext('2d');
            if(myChart) myChart.destroy();
            myChart = new Chart(ctx, {
                type: 'doughnut',
                data: { labels: Object.keys(cats), datasets: [{ data: Object.values(cats), backgroundColor: ['#fbbf24', '#38bdf8', '#818cf8', '#f87171', '#34d399'], borderWidth: 0 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right', labels: { boxWidth: 8, font: { size: 9 } } } }, cutout: '70%' }
            });
        }

        h_renderTripList();
    </script>
</body>
</html>
